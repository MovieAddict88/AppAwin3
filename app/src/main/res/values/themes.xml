<?xml version="1.0" encoding="utf-8"?>
<resources>
    
    <!-- Base Theme -->
    <style name="Theme.FoodDay" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryContainer">@color/primary_light</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>
        
        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_light</item>
        <item name="colorOnSecondary">@color/text_on_secondary</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>
        
        <!-- Background & Surface -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/card_background</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        
        <!-- Error Colors -->
        <item name="colorError">@color/error</item>
        <item name="colorErrorContainer">@color/error_light</item>
        <item name="colorOnError">@color/surface</item>
        
        <!-- Outline -->
        <item name="colorOutline">@color/border</item>
        
        <!-- Status Bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        
        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar">true</item>
        
        <!-- Typography - Use system fonts -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.FoodDay.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.FoodDay.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/TextAppearance.FoodDay.DisplaySmall</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.FoodDay.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.FoodDay.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.FoodDay.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.FoodDay.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.FoodDay.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.FoodDay.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.FoodDay.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.FoodDay.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.FoodDay.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.FoodDay.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.FoodDay.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.FoodDay.LabelSmall</item>
        
        <!-- Shape Appearance -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.FoodDay.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.FoodDay.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.FoodDay.LargeComponent</item>
    </style>
    
    <!-- Splash Theme -->
    <style name="Theme.FoodDay.Splash" parent="Theme.FoodDay">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    
    <!-- Typography Styles - Using system fonts -->
    <style name="TextAppearance.FoodDay.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.FoodDay.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.FoodDay.DisplaySmall" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.FoodDay.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.FoodDay.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.FoodDay.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.FoodDay.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.FoodDay.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.FoodDay.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.FoodDay.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.FoodDay.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.FoodDay.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <style name="TextAppearance.FoodDay.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.FoodDay.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.FoodDay.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <!-- Shape Appearance -->
    <style name="ShapeAppearance.FoodDay.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    
    <style name="ShapeAppearance.FoodDay.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    
    <style name="ShapeAppearance.FoodDay.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
    
    <!-- Button Styles -->
    <style name="Widget.FoodDay.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">56dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.FoodDay.MediumComponent</item>
    </style>
    
    <style name="Widget.FoodDay.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">56dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.FoodDay.MediumComponent</item>
    </style>
    
    <style name="Widget.FoodDay.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:minHeight">48dp</item>
    </style>
    
    <!-- Card Styles -->
    <style name="Widget.FoodDay.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardElevation">2dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.FoodDay.MediumComponent</item>
    </style>
    
    <!-- Text Input Styles -->
    <style name="Widget.FoodDay.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/border</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="shapeAppearance">@style/ShapeAppearance.FoodDay.MediumComponent</item>
    </style>
    
    <style name="Widget.FoodDay.TextInputLayout.Filled" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/background</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="shapeAppearance">@style/ShapeAppearance.FoodDay.MediumComponent</item>
    </style>
    
    <!-- Bottom Navigation -->
    <style name="Widget.FoodDay.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/surface</item>
        <item name="itemIconTint">@color/bottom_nav_colors</item>
        <item name="itemTextColor">@color/bottom_nav_colors</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.FoodDay.BottomNavigation.Indicator</item>
    </style>
    
    <style name="Widget.FoodDay.BottomNavigation.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primary_light</item>
    </style>
    
</resources>
